# Application
PORT=3000
NODE_ENV=production

# ── Traefik ───────────────────────────────────────────────────────────────────
APP_HOST=minha-app.meudominio.com
TRAEFIK_CERT_RESOLVER=letsencrypt

# ── Sentry (self-hosted) ──────────────────────────────────────────────────────
# Sentry > Projeto > Settings > SDK Setup > DSN
# Formato obrigatório: https://<chave-publica>@sentry.meudominio.com/<project-id>
SENTRY_DSN=https://abc123def456@sentry.meudominio.com/1

# ── GitHub ────────────────────────────────────────────────────────────────────
# Settings > Developer settings > Personal access tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── N8N (self-hosted) ─────────────────────────────────────────────────────────
N8N_URL=https://n8n.meudominio.com
N8N_API_KEY=

# ── Groq LLM ─────────────────────────────────────────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Slack ─────────────────────────────────────────────────────────────────────
# Slack > Your Apps > Incoming Webhooks > Activate > Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/xxxxxxxxxxxxxxxx

# ── Bugs / Monitor ────────────────────────────────────────────────────────────
# Intervalo do monitor de fila em background (BUG-002). Padrão: 60000ms (1min)
MONITOR_INTERVAL_MS=60000
